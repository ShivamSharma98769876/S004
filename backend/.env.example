# Copy to .env and adjust.
DATABASE_URL=postgresql://user:pass@localhost:5432/tradingpro

# Fernet key for encrypting per-user broker vault + admin shared broker (generate once):
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# S004_CREDENTIALS_FERNET_KEY=

# Open-position monitor (LIVE broker exits + PAPER DB exits): poll interval in seconds (min 1). Uses Kite quotes, not option chain.
# POSITION_MONITOR_POLL_SEC=5
# If you see socket.gaierror / getaddrinfo failed (Windows 11001): the hostname in DATABASE_URL is not resolving.
# Try: nslookup <your-db-host> — fix VPN/DNS, or use local Postgres: postgresql://user:pass@127.0.0.1:5432/tradingpro

# Seconds to wait after stopping background tasks before closing the DB pool (reduces "pool is closing" on Ctrl+C).
# DB_POOL_CLOSE_DELAY_SEC=1.0

# Option chain for recommendations: default requires Zerodha Kite (apiKey + accessToken in Settings).
# Set to 0 only for local/dev without Kite — uses synthetic chain (not for production).
# OPTION_CHAIN_REQUIRE_LIVE=0

# Rolling snapshots per (NIFTY, expiry) for option-leg LTP history. Short-premium ema_cross_vwap needs ~23+ points;
# default 30 (max 60). Lower values can yield zero scanned candidates until history fills.
# OPTION_CHAIN_RECENT_WINDOW=30

# Optional: comma-separated RSS URLs for Landing "News pulse" (defaults to ET Markets + Moneycontrol business).
# NEWS_RSS_URLS=https://example.com/feed.xml
# NEWS_SENTIMENT_CACHE_SEC=480
# NEWS_SENTIMENT_MAX_ITEMS=14

# Optional: platform settings cache + landing sentiment replay (docker-compose maps redis:6379)
# REDIS_URL=redis://localhost:6379/0
# When REDIS_URL is set, /api/landing/sentiment-history uses a capped Redis list per user (no extra Postgres tables).
# SENTIMENT_HISTORY_REDIS_TTL_SEC=172800

# Optional: human-readable .log files for recommendation runs (strategy + per-user copies). IST date folders;
# each block includes IST time, score/auto-trade thresholds, position intent, and per-candidate EMA/VWAP/RSI when present.
# Relative paths are from the process current working directory (e.g. run uvicorn from backend/).
# S004_EVALUATION_LOG_DIR=logs/evaluation
# Optional: max candidate lines per snapshot (0 = unlimited).
# S004_EVALUATION_LOG_MAX_CANDIDATES=500
# Cap short-premium strike/leg diagnostic lines in each snapshot (default 48, max 80).
# S004_EVALUATION_LOG_MAX_DIAGNOSTIC_LEGS=48

# Short premium + shortPremiumDeltaVixBands: minimum strikes each side when selecting by delta only (default 12, max 20).
# S004_SHORT_PREMIUM_DELTA_ONLY_STRIKES_EACH_SIDE=12

# Short premium otm_steps + tight deltaMinAbs/deltaMaxAbs: widen fetch and OTM cap (default 12, max 20) when not delta-only.
# S004_SHORT_PREMIUM_TIGHT_DELTA_STRIKES_EACH_SIDE=12

# Short-premium evaluation .log: default is compact (delta gate + strikes in band only). Set to 1 for full diagnostics.
# S004_EVALUATION_LOG_SHORT_FULL=0
# Long premium (e.g. TrendSnap): append per-strike candidate blocks to the strategy .log (can be large).
# S004_EVALUATION_LOG_LONG_CANDIDATES=1

# Short-premium per-leg diagnostics: default skips legs outside the active VIX delta band. Set to 1 to include them.
# S004_SHORT_DIAGNOSTICS_INCLUDE_OOB_DELTA=0
