# Base URL for Next.js rewrites (/api/* → API). Must match the port where FastAPI runs.
# Default uvicorn: cd backend && uvicorn app.main:app --reload --host 127.0.0.1 --port 8000
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
# If you see ECONNRESET / "socket hang up" on slow APIs: next.config.mjs sets experimental.proxyTimeout (dev proxy).
# Also confirm the backend is up on this host/port (same value as NEXT_PUBLIC_API_URL).
